{
  "name": "hpack-html",
  "version": "0.1.0",
  "description": "High-performance lossless HTML compression format — core library + decompressor",
  "author": "Andre Ferreira <andrehrf@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrehrferreira/hpack-html.git",
    "directory": "packages/hpack-html"
  },
  "bugs": {
    "url": "https://github.com/andrehrferreira/hpack-html/issues"
  },
  "homepage": "https://github.com/andrehrferreira/hpack-html#readme",
  "keywords": ["html", "compression", "deflate", "hpack", "crawler", "decompressor"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "fflate": "^0.8.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
